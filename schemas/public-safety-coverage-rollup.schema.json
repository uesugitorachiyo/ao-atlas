{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "ao.atlas.public-safety-coverage-rollup.v0.1",
  "title": "AO Atlas Public Safety Coverage Rollup",
  "type": "object",
  "required": [
    "schema",
    "node_id",
    "status",
    "source_readback_path",
    "source_readback_digest",
    "evidence_root",
    "completed_nodes_before",
    "ready_nodes_before",
    "first_executable_node_before",
    "final_response_allowed_before",
    "exact_next_action_before",
    "public_safety_scan_status",
    "sentinel_evidence_count",
    "completed_nodes_with_sentinel",
    "missing_sentinel_nodes",
    "scoped_scan_count",
    "sentinel_evidence_files",
    "scoped_scan_files",
    "scanned_file_count_total",
    "changed_evidence_files_total",
    "changed_prompt_artifacts_total",
    "unsafe_match_count_total",
    "all_completed_nodes_covered",
    "all_sentinel_statuses_passed",
    "all_scoped_scans_passed",
    "public_safety_scan_passed",
    "machine_readable_closure_rollup",
    "schedules_work",
    "executes_work",
    "approves_work",
    "claims_authority_advance",
    "rsi_remains_denied"
  ],
  "properties": {
    "schema": {
      "const": "ao.atlas.public-safety-coverage-rollup.v0.1"
    },
    "node_id": {
      "type": "string",
      "minLength": 1
    },
    "status": {
      "enum": [
        "passed",
        "failed"
      ]
    },
    "source_readback_path": {
      "type": "string",
      "minLength": 1
    },
    "source_readback_digest": {
      "type": "string",
      "pattern": "^sha256:[0-9a-f]{64}$"
    },
    "evidence_root": {
      "type": "string",
      "minLength": 1
    },
    "completed_nodes_before": {
      "type": "integer",
      "minimum": 1
    },
    "ready_nodes_before": {
      "type": "integer",
      "minimum": 0
    },
    "first_executable_node_before": {
      "type": "string",
      "minLength": 1
    },
    "final_response_allowed_before": {
      "const": false
    },
    "exact_next_action_before": {
      "type": "string",
      "minLength": 1
    },
    "public_safety_scan_status": {
      "enum": [
        "passed",
        "failed",
        "required_pending_verification"
      ]
    },
    "sentinel_evidence_count": {
      "type": "integer",
      "minimum": 1
    },
    "completed_nodes_with_sentinel": {
      "type": "integer",
      "minimum": 0
    },
    "missing_sentinel_nodes": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "scoped_scan_count": {
      "type": "integer",
      "minimum": 1
    },
    "sentinel_evidence_files": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "scoped_scan_files": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "scanned_file_count_total": {
      "type": "integer",
      "minimum": 1
    },
    "changed_evidence_files_total": {
      "type": "integer",
      "minimum": 1
    },
    "changed_prompt_artifacts_total": {
      "type": "integer",
      "minimum": 1
    },
    "unsafe_match_count_total": {
      "type": "integer",
      "minimum": 0
    },
    "all_completed_nodes_covered": {
      "type": "boolean"
    },
    "all_sentinel_statuses_passed": {
      "type": "boolean"
    },
    "all_scoped_scans_passed": {
      "type": "boolean"
    },
    "public_safety_scan_passed": {
      "type": "boolean"
    },
    "machine_readable_closure_rollup": {
      "const": true
    },
    "schedules_work": {
      "const": false
    },
    "executes_work": {
      "const": false
    },
    "approves_work": {
      "const": false
    },
    "claims_authority_advance": {
      "const": false
    },
    "rsi_remains_denied": {
      "const": true
    }
  },
  "additionalProperties": false
}
