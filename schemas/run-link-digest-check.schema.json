{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "ao.atlas.run-link-digest-check.v0.1",
  "title": "AO Atlas Run-Link Digest Check",
  "type": "object",
  "required": [
    "schema",
    "node_id",
    "status",
    "source_run_link_path",
    "source_run_link_file_digest",
    "task_id",
    "run_link_status",
    "recorded_digest",
    "recomputed_digest",
    "digest_matches",
    "evidence_root",
    "evidence_count",
    "schema_bound_evidence_count",
    "missing_evidence",
    "evidence_entries",
    "schedules_work",
    "executes_work",
    "approves_work",
    "claims_authority_advance",
    "rsi_remains_denied"
  ],
  "additionalProperties": false,
  "properties": {
    "schema": { "const": "ao.atlas.run-link-digest-check.v0.1" },
    "node_id": { "type": "string", "minLength": 1 },
    "status": { "const": "run_link_digest_verified" },
    "source_run_link_path": { "type": "string", "minLength": 1 },
    "source_run_link_file_digest": {
      "type": "string",
      "pattern": "^sha256:[0-9a-f]{64}$"
    },
    "task_id": { "type": "string", "minLength": 1 },
    "run_link_status": { "const": "completed" },
    "recorded_digest": {
      "type": "string",
      "pattern": "^sha256:[0-9a-f]{64}$"
    },
    "recomputed_digest": {
      "type": "string",
      "pattern": "^sha256:[0-9a-f]{64}$"
    },
    "digest_matches": { "const": true },
    "evidence_root": { "type": "string", "minLength": 1 },
    "evidence_count": { "type": "integer", "minimum": 1 },
    "schema_bound_evidence_count": { "type": "integer", "minimum": 1 },
    "missing_evidence": {
      "type": "array",
      "maxItems": 0
    },
    "evidence_entries": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/evidence_entry" }
    },
    "schedules_work": { "const": false },
    "executes_work": { "const": false },
    "approves_work": { "const": false },
    "claims_authority_advance": { "const": false },
    "rsi_remains_denied": { "const": true }
  },
  "$defs": {
    "evidence_entry": {
      "type": "object",
      "required": [
        "key",
        "path",
        "schema",
        "status"
      ],
      "additionalProperties": false,
      "properties": {
        "key": { "type": "string", "minLength": 1 },
        "path": { "type": "string", "minLength": 1 },
        "schema": { "type": "string", "minLength": 1 },
        "status": { "const": "schema_bound" }
      }
    }
  }
}
