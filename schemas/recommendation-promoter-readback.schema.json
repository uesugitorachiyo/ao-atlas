{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "ao.atlas.recommendation-promoter-readback.v0.1",
  "type": "object",
  "required": [
    "schema",
    "status",
    "mission_id",
    "promotion_claimed",
    "rsi_remains_denied",
    "no_promotion_summary",
    "next_denied_class",
    "reason",
    "elapsed_minutes",
    "min_minutes_met",
    "lease_health_status",
    "checkpoint_freshness_status",
    "continuation_contract_reason",
    "final_response_allowed",
    "schedules_work",
    "executes_work",
    "approves_work",
    "claims_authority_advance"
  ],
  "additionalProperties": false,
  "properties": {
    "schema": { "const": "ao.atlas.recommendation-promoter-readback.v0.1" },
    "status": { "const": "no_promotion" },
    "mission_id": { "type": "string", "minLength": 1 },
    "evidence_root": { "type": "string" },
    "promotion_claimed": { "const": false },
    "rsi_remains_denied": { "const": true },
    "no_promotion_summary": { "const": "No mutation authority promotion claimed; RSI remains denied." },
    "next_denied_class": { "const": "RSI" },
    "reason": { "type": "string", "minLength": 1 },
    "elapsed_minutes": { "type": "integer", "minimum": 0 },
    "min_minutes_met": { "type": "boolean" },
    "lease_health_status": { "type": "string", "minLength": 1 },
    "checkpoint_freshness_status": { "type": "string", "minLength": 1 },
    "continuation_contract_reason": {
      "enum": [
        "ready_nodes_or_exact_next_action_remain",
        "ready_nodes_remain",
        "exact_next_action_remains",
        "final response allowed by recommendation readback",
        "blocked_hard_blocker",
        "blocked_lease_timing_missing",
        "blocked_minimum_minutes_unmet",
        "blocked_ready_nodes_remain",
        "blocked_no_executable_ready_node"
      ]
    },
    "final_response_allowed": { "type": "boolean" },
    "schedules_work": { "const": false },
    "executes_work": { "const": false },
    "approves_work": { "const": false },
    "claims_authority_advance": { "const": false }
  }
}
