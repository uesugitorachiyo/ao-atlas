{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "ao.atlas.recommendation-foundry-rollup.v0.1",
  "type": "object",
  "required": [
    "schema",
    "status",
    "mission_id",
    "completed_nodes",
    "ready_nodes",
    "blocked_nodes",
    "failed_nodes",
    "total_nodes",
    "node_completion_status",
    "lease_completion_status",
    "lease_health_status",
    "checkpoint_freshness_status",
    "checkpoint_count",
    "final_response_allowed",
    "exact_next_action",
    "continuation_contract_reason",
    "schedules_work",
    "executes_work",
    "approves_work",
    "claims_authority_advance"
  ],
  "additionalProperties": false,
  "properties": {
    "schema": { "const": "ao.atlas.recommendation-foundry-rollup.v0.1" },
    "status": { "type": "string", "minLength": 1 },
    "mission_id": { "type": "string", "minLength": 1 },
    "evidence_root": { "type": "string" },
    "completed_nodes": { "type": "integer", "minimum": 0 },
    "ready_nodes": { "type": "integer", "minimum": 0 },
    "blocked_nodes": { "type": "integer", "minimum": 0 },
    "failed_nodes": { "type": "integer", "minimum": 0 },
    "total_nodes": { "type": "integer", "minimum": 1 },
    "node_completion_status": { "type": "string", "minLength": 1 },
    "lease_completion_status": { "type": "string", "minLength": 1 },
    "lease_health_status": { "type": "string", "minLength": 1 },
    "checkpoint_freshness_status": { "type": "string", "minLength": 1 },
    "return_gate_status": { "type": "string", "minLength": 1 },
    "checkpoint_count": { "type": "integer", "minimum": 0 },
    "final_response_allowed": { "type": "boolean" },
    "exact_next_action": { "type": "string", "minLength": 1 },
    "continuation_contract_reason": {
      "enum": [
        "ready_nodes_or_exact_next_action_remain",
        "ready_nodes_remain",
        "exact_next_action_remains",
        "final response allowed by recommendation readback",
        "blocked_hard_blocker",
        "blocked_lease_timing_missing",
        "blocked_minimum_minutes_unmet",
        "blocked_ready_nodes_remain",
        "blocked_no_executable_ready_node"
      ]
    },
    "schedules_work": { "const": false },
    "executes_work": { "const": false },
    "approves_work": { "const": false },
    "claims_authority_advance": { "const": false }
  }
}
