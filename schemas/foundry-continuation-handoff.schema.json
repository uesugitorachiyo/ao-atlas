{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "ao.atlas.foundry-continuation-handoff.v0.1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "contract_version",
    "id",
    "target_folder",
    "command",
    "next_recommended_action",
    "prompt",
    "blueprint_pack_path",
    "atlas_import_path",
    "workgraph_path",
    "foundry_import_path",
    "first_safe_node",
    "total_node_count",
    "completed_node_count",
    "blocked_node_count",
    "ready_node_count",
    "class_boundary",
    "stop_conditions",
    "safety_prohibitions",
    "schedules_work",
    "executes_work",
    "approves_work"
  ],
  "properties": {
    "contract_version": {
      "const": "ao.atlas.foundry-continuation-handoff.v0.1"
    },
    "id": {
      "type": "string",
      "minLength": 1
    },
    "target_folder": {
      "type": "string",
      "minLength": 1
    },
    "command": {
      "const": "codex --yolo"
    },
    "next_recommended_action": {
      "type": "string",
      "minLength": 1
    },
    "prompt": {
      "type": "string",
      "minLength": 1
    },
    "blueprint_pack_path": {
      "type": "string",
      "minLength": 1
    },
    "atlas_import_path": {
      "type": "string",
      "minLength": 1
    },
    "workgraph_path": {
      "type": "string",
      "minLength": 1
    },
    "foundry_import_path": {
      "type": "string",
      "minLength": 1
    },
    "mission_continuation_evidence_path": {
      "type": "string",
      "minLength": 1
    },
    "first_safe_node": {
      "type": "string",
      "minLength": 1
    },
    "total_node_count": {
      "type": "integer",
      "minimum": 1
    },
    "completed_node_count": {
      "type": "integer",
      "minimum": 0
    },
    "blocked_node_count": {
      "type": "integer",
      "minimum": 0
    },
    "ready_node_count": {
      "type": "integer",
      "minimum": 1
    },
    "class_boundary": {
      "type": "string",
      "minLength": 1
    },
    "stop_conditions": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "safety_prohibitions": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "schedules_work": {
      "const": false
    },
    "executes_work": {
      "const": false
    },
    "approves_work": {
      "const": false
    }
  }
}
