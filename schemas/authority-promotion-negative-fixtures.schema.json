{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "ao.atlas.authority-promotion-negative-fixtures.v0.1",
  "title": "AO Atlas Authority Promotion Negative Fixtures",
  "type": "object",
  "required": [
    "schema",
    "node_id",
    "status",
    "fixture_encoding",
    "scanner_contract",
    "case_count",
    "cases",
    "forbidden_patterns_redacted",
    "unsafe_literal_stored",
    "expected_scan_status",
    "expected_public_safety_scan_passed",
    "schedules_work",
    "executes_work",
    "approves_work",
    "claims_authority_advance",
    "rsi_remains_denied"
  ],
  "properties": {
    "schema": {
      "const": "ao.atlas.authority-promotion-negative-fixtures.v0.1"
    },
    "node_id": {
      "type": "string",
      "minLength": 1
    },
    "status": {
      "const": "passed"
    },
    "fixture_encoding": {
      "const": "redacted_token_sequences"
    },
    "scanner_contract": {
      "const": "ao.atlas.scoped-public-safety-scan.v0.1"
    },
    "case_count": {
      "type": "integer",
      "minimum": 1
    },
    "cases": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "id",
          "scanner_pattern_id",
          "category",
          "statement_tokens",
          "expected_scan_status",
          "expected_unsafe_matches",
          "redaction_note"
        ],
        "properties": {
          "id": {
            "type": "string",
            "minLength": 1
          },
          "scanner_pattern_id": {
            "type": "string",
            "minLength": 1
          },
          "category": {
            "type": "string",
            "minLength": 1
          },
          "statement_tokens": {
            "type": "array",
            "minItems": 2,
            "items": {
              "type": "string",
              "minLength": 1
            }
          },
          "expected_scan_status": {
            "const": "failed"
          },
          "expected_unsafe_matches": {
            "type": "integer",
            "minimum": 1
          },
          "redaction_note": {
            "type": "string",
            "minLength": 1
          }
        },
        "additionalProperties": false
      }
    },
    "forbidden_patterns_redacted": {
      "const": true
    },
    "unsafe_literal_stored": {
      "const": false
    },
    "expected_scan_status": {
      "const": "failed"
    },
    "expected_public_safety_scan_passed": {
      "const": false
    },
    "schedules_work": {
      "const": false
    },
    "executes_work": {
      "const": false
    },
    "approves_work": {
      "const": false
    },
    "claims_authority_advance": {
      "const": false
    },
    "rsi_remains_denied": {
      "const": true
    }
  },
  "additionalProperties": false
}
