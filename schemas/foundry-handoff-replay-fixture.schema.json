{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "ao.atlas.foundry-handoff-replay-fixture.v0.1",
  "title": "AO Atlas Foundry Handoff Replay Fixture",
  "type": "object",
  "required": [
    "schema",
    "node_id",
    "status",
    "source_readback_path",
    "source_readback_digest",
    "source_workgraph_path",
    "source_workgraph_digest",
    "foundry_import_path",
    "foundry_import_digest",
    "foundry_handoff_path",
    "foundry_handoff_digest",
    "resumed_first_executable_node",
    "resumed_exact_next_action",
    "completed_nodes_before",
    "ready_nodes_before",
    "final_response_allowed",
    "active_node_id",
    "active_task_id",
    "foundry_task_count",
    "handoff_first_safe_node",
    "workgraph_next_ready_node",
    "mutation_class",
    "single_active_import_task",
    "handoff_matches_resumed_readback",
    "import_matches_resumed_readback",
    "handoff_matches_workgraph",
    "bounded_mutation_class",
    "exact_next_action_names_active_node",
    "prompt_preserves_active_node",
    "replay_assertions",
    "schedules_work",
    "executes_work",
    "approves_work",
    "claims_authority_advance",
    "rsi_remains_denied"
  ],
  "additionalProperties": false,
  "properties": {
    "schema": { "const": "ao.atlas.foundry-handoff-replay-fixture.v0.1" },
    "node_id": { "type": "string", "minLength": 1 },
    "status": { "const": "replay_guarded" },
    "source_readback_path": { "type": "string", "minLength": 1 },
    "source_readback_digest": {
      "type": "string",
      "pattern": "^sha256:[0-9a-f]{64}$"
    },
    "source_workgraph_path": { "type": "string", "minLength": 1 },
    "source_workgraph_digest": {
      "type": "string",
      "pattern": "^sha256:[0-9a-f]{64}$"
    },
    "foundry_import_path": { "type": "string", "minLength": 1 },
    "foundry_import_digest": {
      "type": "string",
      "pattern": "^sha256:[0-9a-f]{64}$"
    },
    "foundry_handoff_path": { "type": "string", "minLength": 1 },
    "foundry_handoff_digest": {
      "type": "string",
      "pattern": "^sha256:[0-9a-f]{64}$"
    },
    "resumed_first_executable_node": { "type": "string", "minLength": 1 },
    "resumed_exact_next_action": { "type": "string", "minLength": 1 },
    "completed_nodes_before": { "type": "integer", "minimum": 1 },
    "ready_nodes_before": { "type": "integer", "minimum": 1 },
    "final_response_allowed": { "const": false },
    "active_node_id": { "type": "string", "minLength": 1 },
    "active_task_id": { "type": "string", "minLength": 1 },
    "foundry_task_count": { "const": 1 },
    "handoff_first_safe_node": { "type": "string", "minLength": 1 },
    "workgraph_next_ready_node": { "type": "string", "minLength": 1 },
    "mutation_class": { "const": "low_risk_code" },
    "single_active_import_task": { "const": true },
    "handoff_matches_resumed_readback": { "const": true },
    "import_matches_resumed_readback": { "const": true },
    "handoff_matches_workgraph": { "const": true },
    "bounded_mutation_class": { "const": true },
    "exact_next_action_names_active_node": { "const": true },
    "prompt_preserves_active_node": { "const": true },
    "replay_assertions": {
      "type": "array",
      "minItems": 6,
      "items": { "type": "string", "minLength": 1 }
    },
    "schedules_work": { "const": false },
    "executes_work": { "const": false },
    "approves_work": { "const": false },
    "claims_authority_advance": { "const": false },
    "rsi_remains_denied": { "const": true }
  }
}
