{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "ao.atlas.recommendation-reconciliation-packet.v0.1",
  "type": "object",
  "required": [
    "schema",
    "status",
    "mission_id",
    "completed_nodes",
    "ready_nodes",
    "blocked_nodes",
    "failed_nodes",
    "total_nodes",
    "checkpoint_count",
    "return_gate_status",
    "lease_time_status",
    "final_response_allowed",
    "final_response_reason",
    "exact_next_action",
    "command_return_gate_status",
    "command_final_response_allowed",
    "promoter_status",
    "promotion_claimed",
    "rsi_remains_denied",
    "foundry_status",
    "foundry_return_gate_status",
    "foundry_node_completion_status",
    "foundry_lease_completion_status",
    "foundry_final_response_allowed",
    "artifacts_agree",
    "schedules_work",
    "executes_work",
    "approves_work",
    "claims_authority_advance"
  ],
  "additionalProperties": false,
  "properties": {
    "schema": { "const": "ao.atlas.recommendation-reconciliation-packet.v0.1" },
    "status": { "enum": ["continuation_required", "ready", "blocked_stale_artifact"] },
    "mission_id": { "type": "string", "minLength": 1 },
    "evidence_root": { "type": "string" },
    "completed_nodes": { "type": "integer", "minimum": 0 },
    "ready_nodes": { "type": "integer", "minimum": 0 },
    "blocked_nodes": { "type": "integer", "minimum": 0 },
    "failed_nodes": { "type": "integer", "minimum": 0 },
    "total_nodes": { "type": "integer", "minimum": 1 },
    "checkpoint_count": { "type": "integer", "minimum": 0 },
    "return_gate_status": { "type": "string", "minLength": 1 },
    "lease_time_status": { "type": "string", "minLength": 1 },
    "final_response_allowed": { "type": "boolean" },
    "final_response_reason": { "type": "string", "minLength": 1 },
    "exact_next_action": { "type": "string", "minLength": 1 },
    "command_return_gate_status": { "type": "string", "minLength": 1 },
    "command_final_response_allowed": { "type": "boolean" },
    "promoter_status": { "type": "string", "minLength": 1 },
    "promotion_claimed": { "const": false },
    "rsi_remains_denied": { "const": true },
    "foundry_status": { "type": "string", "minLength": 1 },
    "foundry_return_gate_status": { "type": "string", "minLength": 1 },
    "foundry_node_completion_status": { "type": "string", "minLength": 1 },
    "foundry_lease_completion_status": { "type": "string", "minLength": 1 },
    "foundry_final_response_allowed": { "type": "boolean" },
    "artifacts_agree": { "type": "boolean" },
    "schedules_work": { "const": false },
    "executes_work": { "const": false },
    "approves_work": { "const": false },
    "claims_authority_advance": { "const": false }
  }
}
