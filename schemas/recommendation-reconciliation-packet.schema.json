{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "ao.atlas.recommendation-reconciliation-packet.v0.1",
  "type": "object",
  "required": [
    "schema",
    "status",
    "mission_id",
    "final_state_reconciliation",
    "completed_nodes",
    "ready_nodes",
    "blocked_nodes",
    "failed_nodes",
    "total_nodes",
    "checkpoint_count",
    "return_gate_status",
    "lease_time_status",
    "lease_health_status",
    "checkpoint_freshness_status",
    "stale_route_decision_status",
    "final_response_allowed",
    "final_response_reason",
    "exact_next_action",
    "continuation_contract_reason",
    "command_return_gate_status",
    "command_continuation_contract_reason",
    "command_final_response_allowed",
    "promoter_status",
    "promoter_continuation_contract_reason",
    "promotion_claimed",
    "rsi_remains_denied",
    "foundry_status",
    "foundry_return_gate_status",
    "foundry_continuation_contract_reason",
    "foundry_node_completion_status",
    "foundry_lease_completion_status",
    "foundry_final_response_allowed",
    "continuation_reason_agreement",
    "artifacts_agree",
    "schedules_work",
    "executes_work",
    "approves_work",
    "claims_authority_advance"
  ],
  "additionalProperties": false,
  "properties": {
    "schema": { "const": "ao.atlas.recommendation-reconciliation-packet.v0.1" },
    "status": { "enum": ["continuation_required", "ready", "blocked_stale_artifact"] },
    "mission_id": { "type": "string", "minLength": 1 },
    "evidence_root": { "type": "string" },
    "final_state_reconciliation": {
      "type": "object",
      "required": [
        "contract_version",
        "status",
        "workgraph_status",
        "foundry_rollup_status",
        "promoter_verdict_status",
        "command_readback_status",
        "exact_next_action",
        "continuation_contract_reason",
        "continuation_reason_agreement",
        "schedules_work",
        "executes_work",
        "approves_work"
      ],
      "additionalProperties": false,
      "properties": {
        "contract_version": { "const": "ao.atlas.final-state-reconciliation.v0.1" },
        "status": { "enum": ["continuation_required", "ready", "blocked_stale_artifact"] },
        "workgraph_status": { "type": "string", "minLength": 1 },
        "foundry_rollup_status": { "type": "string", "minLength": 1 },
        "promoter_verdict_status": { "type": "string", "minLength": 1 },
        "command_readback_status": { "type": "string", "minLength": 1 },
        "exact_next_action": { "type": "string", "minLength": 1 },
        "continuation_contract_reason": {
          "enum": [
            "ready_nodes_or_exact_next_action_remain",
            "ready_nodes_remain",
            "exact_next_action_remains",
            "final response allowed by recommendation readback",
            "blocked_hard_blocker",
            "blocked_lease_timing_missing",
            "blocked_minimum_minutes_unmet",
            "blocked_ready_nodes_remain",
            "blocked_no_executable_ready_node"
          ]
        },
        "continuation_reason_agreement": { "type": "boolean" },
        "schedules_work": { "const": false },
        "executes_work": { "const": false },
        "approves_work": { "const": false }
      }
    },
    "completed_nodes": { "type": "integer", "minimum": 0 },
    "ready_nodes": { "type": "integer", "minimum": 0 },
    "blocked_nodes": { "type": "integer", "minimum": 0 },
    "failed_nodes": { "type": "integer", "minimum": 0 },
    "total_nodes": { "type": "integer", "minimum": 1 },
    "checkpoint_count": { "type": "integer", "minimum": 0 },
    "return_gate_status": { "type": "string", "minLength": 1 },
    "lease_time_status": { "type": "string", "minLength": 1 },
    "lease_health_status": { "type": "string", "minLength": 1 },
    "checkpoint_freshness_status": { "type": "string", "minLength": 1 },
    "stale_route_decision_status": { "type": "string", "minLength": 1 },
    "final_response_allowed": { "type": "boolean" },
    "final_response_reason": { "type": "string", "minLength": 1 },
    "exact_next_action": { "type": "string", "minLength": 1 },
    "continuation_contract_reason": {
      "enum": [
        "ready_nodes_or_exact_next_action_remain",
        "ready_nodes_remain",
        "exact_next_action_remains",
        "final response allowed by recommendation readback",
        "blocked_hard_blocker",
        "blocked_lease_timing_missing",
        "blocked_minimum_minutes_unmet",
        "blocked_ready_nodes_remain",
        "blocked_no_executable_ready_node"
      ]
    },
    "command_return_gate_status": { "type": "string", "minLength": 1 },
    "command_continuation_contract_reason": { "$ref": "#/properties/continuation_contract_reason" },
    "command_final_response_allowed": { "type": "boolean" },
    "promoter_status": { "type": "string", "minLength": 1 },
    "promoter_continuation_contract_reason": { "$ref": "#/properties/continuation_contract_reason" },
    "promotion_claimed": { "const": false },
    "rsi_remains_denied": { "const": true },
    "foundry_status": { "type": "string", "minLength": 1 },
    "foundry_return_gate_status": { "type": "string", "minLength": 1 },
    "foundry_continuation_contract_reason": { "$ref": "#/properties/continuation_contract_reason" },
    "foundry_node_completion_status": { "type": "string", "minLength": 1 },
    "foundry_lease_completion_status": { "type": "string", "minLength": 1 },
    "foundry_final_response_allowed": { "type": "boolean" },
    "continuation_reason_agreement": { "type": "boolean" },
    "artifacts_agree": { "type": "boolean" },
    "schedules_work": { "const": false },
    "executes_work": { "const": false },
    "approves_work": { "const": false },
    "claims_authority_advance": { "const": false }
  }
}
