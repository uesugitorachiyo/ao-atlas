{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "ao.atlas.mission-status.v0.1",
  "type": "object",
  "required": [
    "contract_version",
    "intake_id",
    "workgraph_id",
    "target_instance",
    "completion_status",
    "node_counts",
    "run_links",
    "missing_context_packs",
    "missing_handoffs",
    "next_recommended_action",
    "next_actions",
    "schedules_work",
    "executes_work"
  ],
  "properties": {
    "contract_version": { "const": "ao.atlas.mission-status.v0.1" },
    "intake_id": { "type": "string", "minLength": 1 },
    "workgraph_id": { "type": "string", "minLength": 1 },
    "target_instance": { "type": "string", "minLength": 1 },
    "completion_status": { "enum": ["completed", "blocked", "in_progress"] },
    "node_counts": {
      "type": "object",
      "required": ["ready", "blocked", "completed", "failed"],
      "additionalProperties": { "type": "integer", "minimum": 0 }
    },
    "run_links": {
      "type": "object",
      "additionalProperties": { "enum": ["planned", "running", "completed", "blocked", "failed"] }
    },
    "missing_context_packs": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    },
    "missing_handoffs": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    },
    "next_recommended_action": { "type": "string", "minLength": 1 },
    "next_actions": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 1 }
    },
    "authority_ladder": {
      "type": "object",
      "required": [
        "current_class",
        "next_class",
        "proven_live_classes",
        "dry_run_ready_classes",
        "blockers",
        "required_evidence",
        "denied_higher_classes",
        "do_not_advance_gates"
      ],
      "additionalProperties": false,
      "properties": {
        "current_class": { "type": "string", "minLength": 1 },
        "next_class": { "type": "string", "minLength": 1 },
        "proven_live_classes": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "minLength": 1 }
        },
        "dry_run_ready_classes": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        },
        "blockers": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "minLength": 1 }
        },
        "required_evidence": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "minLength": 1 }
        },
        "denied_higher_classes": {
          "type": "object",
          "minProperties": 1,
          "additionalProperties": { "type": "string", "minLength": 1 }
        },
        "do_not_advance_gates": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "minLength": 1 }
        }
      }
    },
    "schedules_work": { "const": false },
    "executes_work": { "const": false }
  },
  "additionalProperties": false
}
