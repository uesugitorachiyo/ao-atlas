{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "ao.atlas.workgraph-repair-plan.v0.1",
  "type": "object",
  "required": [
    "contract_version",
    "id",
    "task_id",
    "status",
    "source_run_link_status",
    "reason",
    "repair_tasks",
    "schedules_work",
    "executes_work",
    "approves_work"
  ],
  "properties": {
    "contract_version": { "const": "ao.atlas.workgraph-repair-plan.v0.1" },
    "id": { "type": "string", "minLength": 1 },
    "task_id": { "type": "string", "minLength": 1 },
    "status": { "const": "repair_required" },
    "source_run_link_status": { "enum": ["blocked", "failed"] },
    "reason": { "type": "string", "minLength": 1 },
    "repair_tasks": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "factory-task.schema.json" }
    },
    "schedules_work": { "const": false },
    "executes_work": { "const": false },
    "approves_work": { "const": false }
  },
  "additionalProperties": false
}
