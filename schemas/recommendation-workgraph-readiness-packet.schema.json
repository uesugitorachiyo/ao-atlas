{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "ao.atlas.recommendation-workgraph-readiness-packet.v0.1",
  "type": "object",
  "required": [
    "schema",
    "status",
    "mission_id",
    "target_instance",
    "wave_digest",
    "workgraph_digest",
    "readback_digest",
    "total_nodes",
    "minimum_nodes",
    "node_budget",
    "continue_if_fast_target",
    "completed_nodes",
    "ready_nodes",
    "blocked_nodes",
    "failed_nodes",
    "executable_ready_nodes",
    "lease_health_status",
    "checkpoint_freshness_status",
    "return_gate_status",
    "checkpoint_count",
    "early_return_risk_status",
    "continuation_budget_status",
    "final_response_allowed",
    "final_response_reason",
    "exact_next_action",
    "continuation_contract_reason",
    "one_executable_mutation_node_active",
    "refuses_final_response",
    "schedules_work",
    "executes_work",
    "approves_work",
    "claims_authority_advance",
    "rsi_remains_denied"
  ],
  "additionalProperties": false,
  "properties": {
    "schema": { "const": "ao.atlas.recommendation-workgraph-readiness-packet.v0.1" },
    "status": { "enum": ["continuation_required", "ready_for_final_response", "blocked"] },
    "mission_id": { "type": "string", "minLength": 1 },
    "target_instance": { "type": "string", "minLength": 1 },
    "evidence_root": { "type": "string" },
    "wave_digest": { "type": "string", "pattern": "^sha256:[0-9a-f]{64}$" },
    "workgraph_digest": { "type": "string", "pattern": "^sha256:[0-9a-f]{64}$" },
    "readback_digest": { "type": "string", "pattern": "^sha256:[0-9a-f]{64}$" },
    "total_nodes": { "type": "integer", "minimum": 1 },
    "minimum_nodes": { "type": "integer", "minimum": 1 },
    "node_budget": { "type": "integer", "minimum": 1 },
    "continue_if_fast_target": { "type": "integer", "minimum": 1 },
    "completed_nodes": { "type": "integer", "minimum": 0 },
    "ready_nodes": { "type": "integer", "minimum": 0 },
    "blocked_nodes": { "type": "integer", "minimum": 0 },
    "failed_nodes": { "type": "integer", "minimum": 0 },
    "executable_ready_nodes": { "type": "integer", "minimum": 0 },
    "first_executable_node": { "type": "string" },
    "lease_health_status": { "type": "string", "minLength": 1 },
    "checkpoint_freshness_status": { "type": "string", "minLength": 1 },
    "return_gate_status": { "type": "string", "minLength": 1 },
    "checkpoint_count": { "type": "integer", "minimum": 0 },
    "early_return_risk_status": { "type": "string", "minLength": 1 },
    "continuation_budget_status": {
      "enum": [
        "minimum_nodes_unmet_continue_to_40_node_budget",
        "minimum_met_continue_if_fast_budget_open",
        "node_budget_complete_waiting_for_lease_evidence",
        "all_generated_nodes_complete",
        "hard_blocker_requires_repair",
        "continuation_required"
      ]
    },
    "final_response_allowed": { "type": "boolean" },
    "final_response_reason": { "type": "string", "minLength": 1 },
    "exact_next_action": { "type": "string", "minLength": 1 },
    "continuation_contract_reason": {
      "enum": [
        "ready_nodes_or_exact_next_action_remain",
        "ready_nodes_remain",
        "exact_next_action_remains",
        "final response allowed by recommendation readback",
        "blocked_hard_blocker",
        "blocked_lease_timing_missing",
        "blocked_minimum_minutes_unmet",
        "blocked_ready_nodes_remain",
        "blocked_no_executable_ready_node"
      ]
    },
    "one_executable_mutation_node_active": { "type": "boolean" },
    "refuses_final_response": { "type": "boolean" },
    "schedules_work": { "const": false },
    "executes_work": { "const": false },
    "approves_work": { "const": false },
    "claims_authority_advance": { "const": false },
    "rsi_remains_denied": { "const": true }
  }
}
