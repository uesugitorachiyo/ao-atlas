{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "ao.atlas.recommendation-readback.v0.1",
  "type": "object",
  "required": [
    "contract_version",
    "mission_id",
    "target_instance",
    "status",
    "source_digest",
    "elapsed_minutes",
    "min_minutes_met",
    "lease_time_status",
    "total_nodes",
    "minimum_nodes",
    "completed_nodes",
    "ready_nodes",
    "blocked_nodes",
    "failed_nodes",
    "executable_ready_nodes",
    "lease_health_status",
    "checkpoint_freshness_status",
    "stale_route_decision_status",
    "early_return_risk_status",
    "foundry_rollup_status",
    "foundry_terminal_status_readback",
    "promoter_readback_status",
    "promoter_no_promotion_status",
    "command_readback_status",
    "command_timeline_status",
    "public_safety_scan_status",
    "final_response_allowed",
    "final_response_denial_gate",
    "final_response_reason",
    "exact_next_action",
    "node_evidence",
    "feature_depth_recommendations",
    "safety_boundaries",
    "schedules_work",
    "executes_work",
    "approves_work"
  ],
  "additionalProperties": false,
  "properties": {
    "contract_version": { "const": "ao.atlas.recommendation-readback.v0.1" },
    "mission_id": { "type": "string", "minLength": 1 },
    "target_instance": { "type": "string", "minLength": 1 },
    "status": { "enum": ["ready", "in_progress", "blocked", "completed"] },
    "source_digest": { "type": "string", "pattern": "^sha256:[0-9a-f]{64}$" },
    "wave_digest": { "type": "string", "pattern": "^sha256:[0-9a-f]{64}$" },
    "workgraph_digest": { "type": "string", "pattern": "^sha256:[0-9a-f]{64}$" },
    "evidence_root": { "type": "string" },
    "supervisor": { "type": "object" },
    "started_at": { "type": "string" },
    "completed_at": { "type": "string" },
    "elapsed_minutes": { "type": "integer", "minimum": 0 },
    "min_minutes_met": { "type": "boolean" },
    "lease_time_status": { "type": "string", "minLength": 1 },
    "total_nodes": { "type": "integer", "minimum": 1 },
    "minimum_nodes": { "type": "integer", "minimum": 1 },
    "completed_nodes": { "type": "integer", "minimum": 0 },
    "ready_nodes": { "type": "integer", "minimum": 0 },
    "blocked_nodes": { "type": "integer", "minimum": 0 },
    "failed_nodes": { "type": "integer", "minimum": 0 },
    "executable_ready_nodes": { "type": "integer", "minimum": 0 },
    "first_executable_node": { "type": "string" },
    "lease_health_status": { "type": "string", "minLength": 1 },
    "checkpoint_freshness_status": { "type": "string", "minLength": 1 },
    "stale_route_decision_status": { "type": "string", "minLength": 1 },
    "early_return_risk_status": { "type": "string", "minLength": 1 },
    "foundry_rollup_status": { "type": "string", "minLength": 1 },
    "foundry_terminal_status_readback": {
      "type": "object",
      "required": ["completed", "promoted", "denied", "blocked"],
      "additionalProperties": false,
      "properties": {
        "completed": { "type": "string", "minLength": 1 },
        "promoted": { "type": "string", "minLength": 1 },
        "denied": { "type": "string", "minLength": 1 },
        "blocked": { "type": "string", "minLength": 1 }
      }
    },
    "promoter_readback_status": { "type": "string", "minLength": 1 },
    "promoter_no_promotion_status": { "type": "string", "minLength": 1 },
    "command_readback_status": { "type": "string", "minLength": 1 },
    "command_timeline_status": { "type": "string", "minLength": 1 },
    "public_safety_scan_status": { "type": "string", "minLength": 1 },
    "return_gate_status": {
      "enum": [
        "final_response_allowed",
        "blocked_hard_blocker",
        "blocked_lease_timing_missing",
        "blocked_minimum_minutes_unmet",
        "blocked_ready_nodes_remain",
        "blocked_no_executable_ready_node"
      ]
    },
    "checkpoint_count": { "type": "integer", "minimum": 0 },
    "final_response_allowed": { "type": "boolean" },
    "final_response_denial_gate": {
      "enum": [
        "deny_ready_nodes_or_exact_next_action_remain",
        "allow_final_response",
        "blocked_hard_blocker"
      ]
    },
    "final_response_reason": { "type": "string", "minLength": 1 },
    "exact_next_action": { "type": "string", "minLength": 1 },
    "node_evidence": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "node_id",
          "task_id",
          "status",
          "node_gate",
          "candidate_record",
          "rollback_record",
          "implementation_evidence",
          "tests",
          "verification",
          "public_safety_wording",
          "promoter_readback",
          "command_readback",
          "required_gates",
          "verification_commands"
        ],
        "additionalProperties": false,
        "properties": {
          "node_id": { "type": "string", "minLength": 1 },
          "task_id": { "type": "string", "minLength": 1 },
          "status": { "enum": ["ready", "blocked", "completed", "failed"] },
          "node_gate": { "type": "string", "minLength": 1 },
          "candidate_record": { "type": "string", "minLength": 1 },
          "rollback_record": { "type": "string", "minLength": 1 },
          "implementation_evidence": { "type": "string", "minLength": 1 },
          "tests": { "type": "string", "minLength": 1 },
          "verification": { "type": "string", "minLength": 1 },
          "public_safety_wording": { "type": "string", "minLength": 1 },
          "promoter_readback": { "type": "string", "minLength": 1 },
          "command_readback": { "type": "string", "minLength": 1 },
          "required_gates": { "type": "array", "minItems": 1, "items": { "type": "string" } },
          "verification_commands": { "type": "array", "minItems": 1, "items": { "type": "string" } }
        }
      }
    },
    "feature_depth_recommendations": {
      "type": "array",
      "minItems": 10,
      "items": { "type": "string", "minLength": 1 }
    },
    "safety_boundaries": {
      "type": "object",
      "additionalProperties": { "type": "boolean" }
    },
    "schedules_work": { "const": false },
    "executes_work": { "const": false },
    "approves_work": { "const": false }
  }
}
