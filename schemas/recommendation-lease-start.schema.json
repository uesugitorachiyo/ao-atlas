{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "ao.atlas.recommendation-lease-start.v0.1",
  "type": "object",
  "required": [
    "schema",
    "status",
    "mission_id",
    "target_instance",
    "started_at",
    "min_minutes",
    "max_minutes",
    "continue_if_fast_target",
    "checkpoint_policy",
    "wave_digest",
    "workgraph_digest",
    "final_response_allowed",
    "final_response_reason",
    "schedules_work",
    "executes_work",
    "approves_work",
    "mutates_repositories",
    "calls_providers",
    "claims_authority_advance"
  ],
  "additionalProperties": false,
  "properties": {
    "schema": { "const": "ao.atlas.recommendation-lease-start.v0.1" },
    "status": { "const": "started" },
    "mission_id": { "type": "string", "minLength": 1 },
    "target_instance": { "type": "string", "minLength": 1 },
    "evidence_root": { "type": "string" },
    "started_at": { "type": "string", "minLength": 1 },
    "min_minutes": { "type": "integer", "minimum": 1 },
    "max_minutes": { "type": "integer", "minimum": 1 },
    "continue_if_fast_target": { "type": "integer", "minimum": 1 },
    "checkpoint_policy": { "type": "string", "minLength": 1 },
    "wave_digest": { "type": "string", "pattern": "^sha256:[0-9a-f]{64}$" },
    "workgraph_digest": { "type": "string", "pattern": "^sha256:[0-9a-f]{64}$" },
    "final_response_allowed": { "const": false },
    "final_response_reason": { "type": "string", "minLength": 1 },
    "schedules_work": { "const": false },
    "executes_work": { "const": false },
    "approves_work": { "const": false },
    "mutates_repositories": { "const": false },
    "calls_providers": { "const": false },
    "claims_authority_advance": { "const": false }
  }
}
