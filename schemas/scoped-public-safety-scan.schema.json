{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "ao.atlas.scoped-public-safety-scan.v0.1",
  "title": "AO Atlas Scoped Public Safety Scan",
  "type": "object",
  "required": [
    "schema",
    "node_id",
    "status",
    "scanned_scopes",
    "scanned_files",
    "scanned_file_count",
    "changed_evidence_files",
    "changed_prompt_artifacts",
    "forbidden_patterns_redacted",
    "unsafe_match_count",
    "public_safety_scan_passed",
    "schedules_work",
    "executes_work",
    "approves_work",
    "claims_authority_advance",
    "rsi_remains_denied"
  ],
  "properties": {
    "schema": {
      "const": "ao.atlas.scoped-public-safety-scan.v0.1"
    },
    "node_id": {
      "type": "string",
      "minLength": 1
    },
    "status": {
      "enum": [
        "passed",
        "failed"
      ]
    },
    "scanned_scopes": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "scanned_files": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "scanned_file_count": {
      "type": "integer",
      "minimum": 1
    },
    "changed_evidence_files": {
      "type": "integer",
      "minimum": 1
    },
    "changed_prompt_artifacts": {
      "type": "integer",
      "minimum": 1
    },
    "forbidden_patterns_redacted": {
      "const": true
    },
    "unsafe_match_count": {
      "type": "integer",
      "minimum": 0
    },
    "public_safety_scan_passed": {
      "type": "boolean"
    },
    "schedules_work": {
      "const": false
    },
    "executes_work": {
      "const": false
    },
    "approves_work": {
      "const": false
    },
    "claims_authority_advance": {
      "const": false
    },
    "rsi_remains_denied": {
      "const": true
    }
  },
  "additionalProperties": false
}
