{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ao.local/schemas/command-ticket-byte-preservation-fixture.schema.json",
  "title": "AO Atlas Command Ticket Byte Preservation Fixture",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema",
    "status",
    "source_input_path",
    "source_input_digest",
    "case_count",
    "mismatched_cases",
    "byte_preservation_passed",
    "cases",
    "schedules_work",
    "executes_work",
    "approves_work",
    "claims_authority_advance",
    "rsi_remains_denied"
  ],
  "properties": {
    "schema": { "const": "ao.atlas.command-ticket-byte-preservation-fixture.v0.1" },
    "status": { "const": "ticket_bytes_preserved" },
    "source_input_path": { "type": "string", "minLength": 1 },
    "source_input_digest": { "$ref": "#/$defs/sha256" },
    "case_count": { "type": "integer", "minimum": 1 },
    "mismatched_cases": { "const": 0 },
    "byte_preservation_passed": { "const": true },
    "cases": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/case" }
    },
    "schedules_work": { "const": false },
    "executes_work": { "const": false },
    "approves_work": { "const": false },
    "claims_authority_advance": { "const": false },
    "rsi_remains_denied": { "const": true }
  },
  "$defs": {
    "sha256": {
      "type": "string",
      "pattern": "^sha256:[0-9a-f]{64}$"
    },
    "case": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "command_readback_path",
        "ticket_sha256",
        "command_reported_ticket_sha256",
        "bytes_preserved"
      ],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "command_readback_path": { "type": "string", "minLength": 1 },
        "ticket_sha256": { "$ref": "#/$defs/sha256" },
        "command_reported_ticket_sha256": { "$ref": "#/$defs/sha256" },
        "bytes_preserved": { "const": true }
      }
    }
  }
}
