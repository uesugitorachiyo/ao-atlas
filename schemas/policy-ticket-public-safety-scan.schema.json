{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ao.local/schemas/policy-ticket-public-safety-scan.schema.json",
  "title": "AO Atlas Policy Ticket Public Safety Scan",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema",
    "status",
    "source_input_path",
    "source_input_digest",
    "claim_count",
    "blocked_phrase_count",
    "unsafe_claims_found",
    "unsafe_matches",
    "claims",
    "blocked_phrases",
    "schedules_work",
    "executes_work",
    "approves_work",
    "claims_authority_advance",
    "rsi_remains_denied"
  ],
  "properties": {
    "schema": { "const": "ao.atlas.policy-ticket-public-safety-scan.v0.1" },
    "status": { "const": "passed_policy_ticket_public_safety_scan" },
    "source_input_path": { "type": "string", "minLength": 1 },
    "source_input_digest": { "type": "string", "pattern": "^sha256:[0-9a-f]{64}$" },
    "claim_count": { "type": "integer", "minimum": 1 },
    "blocked_phrase_count": { "type": "integer", "minimum": 1 },
    "unsafe_claims_found": { "const": 0 },
    "unsafe_matches": {
      "type": "array",
      "maxItems": 0
    },
    "claims": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 1 }
    },
    "blocked_phrases": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 1 }
    },
    "schedules_work": { "const": false },
    "executes_work": { "const": false },
    "approves_work": { "const": false },
    "claims_authority_advance": { "const": false },
    "rsi_remains_denied": { "const": true }
  }
}
