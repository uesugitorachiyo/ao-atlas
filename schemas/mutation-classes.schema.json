{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "ao.atlas.mutation-classes.v0.1",
  "type": "object",
  "required": ["contract_version", "id", "classes", "schedules_work", "executes_work", "approves_work"],
  "additionalProperties": false,
  "properties": {
    "contract_version": { "const": "ao.atlas.mutation-classes.v0.1" },
    "id": { "type": "string", "minLength": 1 },
    "classes": {
      "type": "array",
      "minItems": 7,
      "items": {
        "type": "object",
        "required": [
          "name",
          "allowed_paths",
          "forbidden_paths",
          "max_files",
          "required_gates",
          "rollback_requirements",
          "ci_requirements",
          "promotion_requirements"
        ],
        "additionalProperties": false,
        "properties": {
          "name": {
            "enum": [
              "docs_only_single_file",
              "docs_only_multi_file",
              "docs_config_only",
              "test_only",
              "low_risk_code",
              "multi_repo_low_risk",
              "complex_repo_mutation"
            ]
          },
          "allowed_paths": {
            "type": "array",
            "minItems": 1,
            "items": { "type": "string", "minLength": 1 }
          },
          "forbidden_paths": {
            "type": "array",
            "minItems": 1,
            "items": { "type": "string", "minLength": 1 }
          },
          "max_files": { "type": "integer", "minimum": 1 },
          "required_gates": {
            "type": "array",
            "minItems": 1,
            "items": { "type": "string", "minLength": 1 }
          },
          "rollback_requirements": {
            "type": "array",
            "minItems": 1,
            "items": { "type": "string", "minLength": 1 }
          },
          "ci_requirements": {
            "type": "array",
            "minItems": 1,
            "items": { "type": "string", "minLength": 1 }
          },
          "promotion_requirements": {
            "type": "array",
            "minItems": 1,
            "items": { "type": "string", "minLength": 1 }
          }
        }
      }
    },
    "schedules_work": { "const": false },
    "executes_work": { "const": false },
    "approves_work": { "const": false }
  }
}
