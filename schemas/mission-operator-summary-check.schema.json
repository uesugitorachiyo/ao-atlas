{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "ao.atlas.mission-operator-summary-check.v0.1",
  "type": "object",
  "required": [
    "schema",
    "status",
    "mission_id",
    "target_instance",
    "source_readback_path",
    "summary_markdown_path",
    "source_readback_digest",
    "completed_nodes",
    "total_nodes",
    "ready_nodes",
    "blocked_nodes",
    "failed_nodes",
    "first_executable_node",
    "exact_next_action",
    "exact_next_action_occurrences",
    "exact_next_action_wording_present",
    "next_executable_node_wording_present",
    "final_response_denied_wording_present",
    "return_gate_status",
    "continuation_contract_reason",
    "early_return_risk_status",
    "final_response_allowed",
    "refuses_final_response",
    "summary_assertions",
    "schedules_work",
    "executes_work",
    "approves_work",
    "claims_authority_advance",
    "rsi_remains_denied"
  ],
  "additionalProperties": false,
  "properties": {
    "schema": { "const": "ao.atlas.mission-operator-summary-check.v0.1" },
    "status": { "const": "passed" },
    "mission_id": { "type": "string", "minLength": 1 },
    "target_instance": { "type": "string", "minLength": 1 },
    "source_readback_path": { "type": "string", "minLength": 1 },
    "summary_markdown_path": { "type": "string", "minLength": 1 },
    "source_readback_digest": { "type": "string", "pattern": "^sha256:[0-9a-f]{64}$" },
    "completed_nodes": { "type": "integer", "minimum": 0 },
    "total_nodes": { "type": "integer", "minimum": 1 },
    "ready_nodes": { "type": "integer", "minimum": 0 },
    "blocked_nodes": { "type": "integer", "minimum": 0 },
    "failed_nodes": { "type": "integer", "minimum": 0 },
    "first_executable_node": { "type": "string", "minLength": 1 },
    "exact_next_action": { "type": "string", "minLength": 1 },
    "exact_next_action_occurrences": { "const": 1 },
    "exact_next_action_wording_present": { "const": true },
    "next_executable_node_wording_present": { "const": true },
    "final_response_denied_wording_present": { "const": true },
    "return_gate_status": { "type": "string", "minLength": 1 },
    "continuation_contract_reason": { "type": "string", "minLength": 1 },
    "early_return_risk_status": { "type": "string", "minLength": 1 },
    "final_response_allowed": { "const": false },
    "refuses_final_response": { "const": true },
    "summary_assertions": {
      "type": "array",
      "minItems": 4,
      "items": { "type": "string", "minLength": 1 },
      "contains": { "const": "exact_next_action_wording_preserved" }
    },
    "schedules_work": { "const": false },
    "executes_work": { "const": false },
    "approves_work": { "const": false },
    "claims_authority_advance": { "const": false },
    "rsi_remains_denied": { "const": true }
  }
}
