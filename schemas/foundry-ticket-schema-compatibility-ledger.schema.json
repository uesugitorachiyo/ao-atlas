{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ao.local/schemas/foundry-ticket-schema-compatibility-ledger.schema.json",
  "title": "AO Atlas Foundry Ticket Schema Compatibility Ledger",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema",
    "status",
    "source_input_path",
    "source_input_digest",
    "entry_count",
    "compatible_entry_count",
    "all_entries_compatible",
    "entries",
    "schedules_work",
    "executes_work",
    "approves_work",
    "claims_authority_advance",
    "rsi_remains_denied"
  ],
  "properties": {
    "schema": { "const": "ao.atlas.foundry-ticket-schema-compatibility-ledger.v0.1" },
    "status": { "const": "foundry_ticket_schema_compatible" },
    "source_input_path": { "type": "string", "minLength": 1 },
    "source_input_digest": { "$ref": "#/$defs/sha256" },
    "entry_count": { "type": "integer", "minimum": 1 },
    "compatible_entry_count": { "type": "integer", "minimum": 1 },
    "all_entries_compatible": { "const": true },
    "entries": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/entry" }
    },
    "schedules_work": { "const": false },
    "executes_work": { "const": false },
    "approves_work": { "const": false },
    "claims_authority_advance": { "const": false },
    "rsi_remains_denied": { "const": true }
  },
  "$defs": {
    "sha256": {
      "type": "string",
      "pattern": "^sha256:[0-9a-f]{64}$"
    },
    "entry": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "producer_schema",
        "consumer_schema",
        "required_fields",
        "compatible"
      ],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "producer_schema": { "type": "string", "minLength": 1 },
        "consumer_schema": { "type": "string", "minLength": 1 },
        "required_fields": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "minLength": 1 }
        },
        "compatible": { "const": true }
      }
    }
  }
}
