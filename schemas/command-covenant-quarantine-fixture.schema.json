{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ao.local/schemas/command-covenant-quarantine-fixture.schema.json",
  "title": "AO Atlas Command Covenant Quarantine Fixture",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema",
    "status",
    "source_input_path",
    "source_input_digest",
    "case_count",
    "rejected_command_acceptance_paths",
    "quarantined_paths",
    "safe_to_accept",
    "all_rejected_acceptance_paths_quarantined",
    "cases",
    "schedules_work",
    "executes_work",
    "approves_work",
    "claims_authority_advance",
    "rsi_remains_denied"
  ],
  "properties": {
    "schema": { "const": "ao.atlas.command-covenant-quarantine-fixture.v0.1" },
    "status": { "const": "rejected_paths_quarantined" },
    "source_input_path": { "type": "string", "minLength": 1 },
    "source_input_digest": { "$ref": "#/$defs/sha256" },
    "case_count": { "type": "integer", "minimum": 1 },
    "rejected_command_acceptance_paths": { "type": "integer", "minimum": 1 },
    "quarantined_paths": { "type": "integer", "minimum": 1 },
    "safe_to_accept": { "const": false },
    "all_rejected_acceptance_paths_quarantined": { "const": true },
    "cases": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/case" }
    },
    "schedules_work": { "const": false },
    "executes_work": { "const": false },
    "approves_work": { "const": false },
    "claims_authority_advance": { "const": false },
    "rsi_remains_denied": { "const": true }
  },
  "$defs": {
    "sha256": {
      "type": "string",
      "pattern": "^sha256:[0-9a-f]{64}$"
    },
    "case": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "command_validation_path",
        "ticket_sha256",
        "covenant_decision",
        "command_would_accept_ticket",
        "covenant_native_reason",
        "quarantine_decision",
        "safe_to_accept"
      ],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "command_validation_path": { "type": "string", "minLength": 1 },
        "ticket_sha256": { "$ref": "#/$defs/sha256" },
        "covenant_decision": { "enum": ["accepted", "rejected"] },
        "command_would_accept_ticket": { "type": "boolean" },
        "covenant_native_reason": { "type": "string" },
        "quarantine_decision": { "enum": ["quarantined", "not_required"] },
        "safe_to_accept": { "type": "boolean" }
      }
    }
  }
}
