{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "ao.atlas.ao-mission-final-synthesis-readback.v0.1",
  "type": "object",
  "required": [
    "contract_version",
    "mission_id",
    "status",
    "source_digest",
    "total_nodes",
    "completed_nodes",
    "ready_nodes",
    "blocked_nodes",
    "minimum_nodes",
    "target_minutes",
    "max_minutes",
    "return_gate_status",
    "final_response_allowed",
    "final_response_reason",
    "atlas_workgraph_status",
    "foundry_rollup",
    "promoter_status",
    "command_readback",
    "event_search_bound",
    "branch_cleanup_bound",
    "merged_prs_final",
    "exact_next_action",
    "feature_depth_next_tasks",
    "rsi_remains_denied",
    "promotion_claimed",
    "claims_authority_advance",
    "safe_to_execute",
    "schedules_work",
    "executes_work",
    "approves_work",
    "mutates_repositories"
  ],
  "properties": {
    "contract_version": { "const": "ao.atlas.ao-mission-final-synthesis-readback.v0.1" },
    "mission_id": { "type": "string", "minLength": 1 },
    "status": { "enum": ["completed", "blocked", "denied"] },
    "source_digest": { "type": "string", "pattern": "^sha256:[0-9a-f]{64}$" },
    "total_nodes": { "type": "integer", "minimum": 0 },
    "completed_nodes": { "type": "integer", "minimum": 0 },
    "ready_nodes": { "type": "integer", "minimum": 0 },
    "blocked_nodes": { "type": "integer", "minimum": 0 },
    "minimum_nodes": { "type": "integer", "minimum": 1 },
    "target_minutes": { "type": "integer", "minimum": 1 },
    "max_minutes": { "type": "integer", "minimum": 1 },
    "return_gate_status": { "type": "string", "minLength": 1 },
    "final_response_allowed": { "type": "boolean" },
    "final_response_reason": { "type": "string", "minLength": 1 },
    "atlas_workgraph_status": { "type": "string", "minLength": 1 },
    "foundry_rollup": { "type": "string", "minLength": 1 },
    "promoter_status": { "type": "string", "minLength": 1 },
    "command_readback": { "type": "string", "minLength": 1 },
    "event_search_bound": { "type": "boolean" },
    "branch_cleanup_bound": { "type": "boolean" },
    "merged_prs_final": { "type": "array", "items": { "type": "integer", "minimum": 1 } },
    "exact_next_action": { "type": "string", "minLength": 1 },
    "feature_depth_next_tasks": {
      "type": "array",
      "minItems": 10,
      "items": { "type": "string", "minLength": 1 }
    },
    "rsi_remains_denied": { "const": true },
    "promotion_claimed": { "const": false },
    "claims_authority_advance": { "const": false },
    "safe_to_execute": { "const": false },
    "schedules_work": { "const": false },
    "executes_work": { "const": false },
    "approves_work": { "const": false },
    "mutates_repositories": { "const": false }
  },
  "additionalProperties": false
}
