{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "ao.atlas.foundry-import.v0.1",
  "type": "object",
  "required": ["contract_version", "id", "workgraph_id", "target_instance", "status", "source_artifacts", "tasks", "schedules_work", "executes_work", "approves_work"],
  "properties": {
    "contract_version": { "const": "ao.atlas.foundry-import.v0.1" },
    "id": { "type": "string", "minLength": 1 },
    "workgraph_id": { "type": "string", "minLength": 1 },
    "target_instance": { "type": "string", "minLength": 1 },
    "status": { "const": "ready_for_foundry_fixture_import" },
    "source_artifacts": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["ref", "digest"],
        "properties": {
          "ref": { "type": "string", "minLength": 1 },
          "digest": { "type": "string", "pattern": "^sha256:[0-9a-f]{64}$" }
        },
        "additionalProperties": false
      }
    },
    "tasks": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "node_id",
          "task_id",
          "path",
          "mutation_class",
          "write_scope",
          "rollback_scope",
          "required_gates",
          "required_evidence",
          "authority_boundary",
          "task",
          "task_digest"
        ],
        "properties": {
          "node_id": { "type": "string", "minLength": 1 },
          "task_id": { "type": "string", "minLength": 1 },
          "path": { "type": "string", "minLength": 1 },
          "mutation_class": {
            "enum": [
              "docs_only_single_file",
              "docs_only_multi_file",
              "docs_config_only",
              "test_only",
              "low_risk_code",
              "multi_repo_low_risk",
              "complex_repo_mutation"
            ]
          },
          "write_scope": {
            "type": "array",
            "minItems": 1,
            "items": { "type": "string", "minLength": 1 }
          },
          "rollback_scope": {
            "type": "array",
            "minItems": 1,
            "items": { "type": "string", "minLength": 1 }
          },
          "required_gates": {
            "type": "array",
            "minItems": 1,
            "items": { "type": "string", "minLength": 1 }
          },
          "required_evidence": {
            "type": "array",
            "minItems": 1,
            "items": { "type": "string", "minLength": 1 }
          },
          "authority_boundary": { "type": "string", "minLength": 1 },
          "task": { "type": "object" },
          "task_digest": { "type": "string", "pattern": "^sha256:[0-9a-f]{64}$" }
        },
        "additionalProperties": false
      }
    },
    "schedules_work": { "const": false },
    "executes_work": { "const": false },
    "approves_work": { "const": false }
  }
}
