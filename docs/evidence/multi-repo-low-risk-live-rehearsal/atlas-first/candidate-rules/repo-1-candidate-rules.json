{
  "schema_version": "ao.atlas.blueprint-candidate-rules.v0.1",
  "project_id": "multi_repo_low_risk-live-rehearsal-blueprint",
  "target_instance": "demo-stack",
  "workgraph_id": "multi-repo-low-risk-live-rehearsal-workgraph",
  "candidate_id": "repo-1-ao-command-test-only",
  "mutation_class": "multi_repo_low_risk",
  "target_factory_repo": "ao-command",
  "factory_folder": "factory/multi-repo-low-risk/repo-1-ao-command",
  "objective": "Prepare repo one for the first governed multi_repo_low_risk rehearsal as a tiny test-only AO Command change, with live execution denied until all downstream gates return exact safe_to_execute=true.",
  "acceptance_criteria": [
    "Atlas import is ready and digest-bound to the Blueprint pack and verified authorization",
    "Foundry import contains only repo-1",
    "repo-2 remains blocked until repo-1 merges and evidence is recorded",
    "safe_to_execute remains false in Atlas artifacts"
  ],
  "non_goals": [
    "do not execute live repo mutation",
    "do not import repo two into Foundry",
    "do not claim multi_repo_low_risk is live-proven",
    "do not touch shared policy, auth, provider, release, deploy, config, secret, dependency, or public-claim surfaces"
  ],
  "write_scope": [
    "repo:ao-command:internal/cli/cli_test.go"
  ],
  "rollback_scope": [
    "repo:ao-command:internal/cli/cli_test.go"
  ],
  "required_gates": [
    "atlas_blueprint_import",
    "atlas_cross_repo_classification",
    "per_repo_covenant_ticket",
    "foundry_per_repo_class_gate",
    "foundry_serial_execution_gate",
    "foundry_cross_repo_sequencing_gate",
    "branch_cleanup_gate",
    "ci_gate",
    "rollback_gate",
    "sentinel_hold_clear_gate",
    "promoter_no_promotion_gate",
    "command_repo_readback",
    "operator_exact_scope_approval"
  ],
  "verification_commands": [
    "go test ./internal/cli -count=1",
    "go test ./... -count=1",
    "go vet ./...",
    "go build ./cmd/ao-command"
  ],
  "required_evidence": [
    "blueprint_pack:ready",
    "blueprint_authorization:ao-atlas",
    "low_risk_code:live_proven",
    "multi_repo_low_risk:denied_until_rehearsal_complete",
    "repo_one:ao-command",
    "repo_two:blocked_until_repo_one_merge_evidence",
    "cross_repo_no_shared_surface",
    "foundry_import:repo_1_only",
    "covenant:safe_to_execute_true_required_later",
    "sentinel:hold_or_clear_required_later",
    "promoter:no_promotion_required_later",
    "command_readback:required_later",
    "ci:required_later"
  ],
  "safety_limits": [
    "safe_to_execute:false",
    "live_execution_proven:false",
    "max_repos:2",
    "serialized_repo_execution_only",
    "repo_2_locked_until:repo-1-merged-evidence-recorded",
    "foundry_import_scope:repo-1-only",
    "deny:concurrent_mutation",
    "deny:dependency_updates",
    "deny:public_claim_broadening",
    "deny:complex_repo_mutation",
    "deny:fully_unsupervised_complex_mutation",
    "deny:rsi"
  ],
  "authority_boundary": "atlas_compile_and_foundry_import_for_repo_one_only",
  "context_refs": [
    "implementation-spec.md",
    "quality-profile.md",
    "candidate-rules.json",
    "candidate-selection.md",
    "authority-boundaries.md",
    "gate-evidence.md",
    "rollback-and-holds.md",
    "public-claims.md",
    "downstream-handoff-prompt.md"
  ],
  "dependency_refs": [
    "repo-2 blocked by stop gate repo-1-merged-evidence-recorded"
  ]
}
